# ─────────────────────────────────────────────────────────────
# EduCast Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────

# LiveKit server WebSocket URL
# LiveKit Cloud: wss://your-project.livekit.cloud
# Self-hosted:   ws://your-server-ip:7880
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Token server URL (the Node.js backend from livekit-token-server/)
# Local dev:     http://localhost:4000
# Railway:       https://your-token-server.up.railway.app
# Render:        https://your-token-server.onrender.com
VITE_TOKEN_SERVER_URL=http://localhost:4000
